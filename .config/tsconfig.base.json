{
  "extends": ["@tsconfig/node22", "@tsconfig/strictest"],
  "include": ["global.d.ts", "../src/**/*", "../tests/**/*"],
  "exclude": ["../tests/**/*.client.test.ts", "../tests/**/*.server.test.ts"],
  "compilerOptions": {
    "types": ["node"],
    "lib": ["DOM", "ESNext"],
    "noEmit": true,
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true
  }
}
