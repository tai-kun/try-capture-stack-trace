{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["**/.history/**", "**/.Trash/**", "**/dist/**", "**/node_modules/**"],
  "plugins": [
    "unicorn",
    "oxc",
    "typescript",
    "import",
    "react",
    "jsdoc",
    "vitest",
    "promise",
    "node"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {},
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true
  }
}
